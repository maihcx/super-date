{
  "name": "super-date",
  "version": "0.0.1",
  "description": "An overlay for the date input element in HTML.",
  "author": "Huỳnh Công Xuân Mai",
  "license": "MIT",
  "sideEffects": false,
  "main": "dist/super-date.umd.js",
  "module": "dist/super-date.esm.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/super-date.esm.js",
      "require": "./dist/super-date.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc --outDir dist/lib --declarationDir dist/types --declaration true && rollup -c",
    "build:ts": "rimraf compiled && tsc -p tsconfig.build.json",
    "watch": "rollup -c --watch",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10.4.1",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.4",
    "mutation-observer": "^1.0.3",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-brotli": "^3.1.0",
    "rollup-plugin-postcss": "^4.0.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "select",
    "dropdown",
    "ui",
    "component",
    "custom-select",
    "searchable-select"
  ],
  "browserslist": [
    ">0.25%",
    "not dead"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/maihcx/super-date"
  },
  "bugs": {
    "url": "https://github.com/maihcx/super-date/issues"
  },
  "homepage": "https://github.com/maihcx/super-date"
}
